# Copy this file to .env and fill in real values. Never commit .env.

PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string
# Get this from Atlas -> Database -> Connect -> Drivers
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/kairos?retryWrites=true&w=majority

# Comma-separated list of allowed frontend origins (no trailing slash)
CLIENT_ORIGIN=http://localhost:5500,https://your-frontend.vercel.app
